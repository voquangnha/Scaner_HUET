<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>HUET SCANNER PRO v2.0 - THPT PHÚ BÀI</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        :root { --primary: #00e5ff; --bg: #121212; --panel: #1e1e1e; }
        body { margin: 0; font-family: 'Segoe UI', Arial; background: var(--bg); color: white; display: flex; flex-direction: column; align-items: center; overflow-x: hidden; }
        
        .header { width: 100%; background: #1a237e; padding: 15px 0; text-align: center; border-bottom: 2px solid var(--primary); box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        
        #camera-view { width: 95%; max-width: 500px; height: 45vh; margin-top: 15px; border-radius: 15px; overflow: hidden; position: relative; border: 2px solid #333; background: #000; }
        video { width: 100%; height: 100%; object-fit: cover; }
        
        /* Hiệu ứng khung ngắm scan */
        .guide-box { position: absolute; top: 10%; left: 10%; right: 10%; bottom: 10%; border: 2px dashed rgba(0, 229, 255, 0.5); pointer-events: none; border-radius: 10px; }

        .gallery { width: 95%; display: flex; overflow-x: auto; gap: 10px; padding: 15px 0; min-height: 100px; scroll-behavior: smooth; }
        .thumb { width: 70px; height: 95px; object-fit: cover; border-radius: 6px; border: 2px solid #444; flex-shrink: 0; transition: 0.3s; cursor: pointer; }
        .thumb.active { border-color: var(--primary); transform: scale(1.1); box-shadow: 0 0 10px var(--primary); }

        /* Trình chỉnh sửa ảnh */
        #editor { width: 95%; max-width: 500px; background: var(--panel); border-radius: 15px; padding: 20px; margin-top: 10px; display: none; box-sizing: border-box; border: 1px solid #333; }
        #editor-canvas { width: 100%; border-radius: 8px; background: #000; margin-bottom: 15px; }
        .slide-group { display: flex; align-items: center; gap: 15px; margin-bottom: 10px; }
        .slide-group label { font-size: 0.85rem; width: 80px; color: #aaa; }
        input[type=range] { flex: 1; accent-color: var(--primary); }

        .btn-group { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 90%; margin: 15px 0; }
        .btn { padding: 15px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; font-size: 0.9rem; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn:active { transform: scale(0.98); }
        .btn-snap { background: var(--primary); color: #1a237e; grid-column: span 2; font-size: 1rem; }
        .btn-pdf { background: #ff5252; color: white; }
        .btn-save-edit { background: #4caf50; color: white; }
        .btn-action { background: #546e7a; color: white; }

        #status { margin-top: 5px; font-size: 0.8rem; color: var(--primary); height: 1.5em; }
        .footer { margin: 20px 0; font-size: 0.75rem; color: #666; }
    </style>
</head>
<body>

    <div class="header">
        <h2 style="margin:0; font-size:1.2rem;">HUET SCANNER PRO v2.0</h2>
        <p style="margin:4px 0 0; font-size:0.75rem; color:#ffca28;">DỰ ÁN STEM: THẦY VÕ QUANG NHÃ</p>
    </div>

    <div id="camera-view">
        <video id="webcam" autoplay playsinline></video>
        <div class="guide-box"></div>
    </div>

    <div class="gallery" id="gallery"></div>

    <div id="editor">
        <canvas id="editor-canvas"></canvas>
        <div class="slide-group">
            <label>Độ sáng</label>
            <input type="range" id="bright" min="-100" max="100" value="0">
        </div>
        <div class="slide-group">
            <label>Tương phản</label>
            <input type="range" id="contrast" min="-100" max="100" value="0">
        </div>
        <div class="btn-group" style="margin: 10px 0 0 0;">
            <button class="btn btn-action" onclick="rotateImg()">🔄 XOAY 90°</button>
            <button class="btn btn-save-edit" onclick="saveEdit()">💾 LƯU TRANG</button>
        </div>
    </div>

    <div class="btn-group">
        <button id="btn-snap" class="btn btn-snap">📸 CHỤP TRANG TÀI LIỆU</button>
        <button class="btn btn-action" onclick="location.reload()">🔄 LÀM MỚI</button>
        <button id="btn-pdf" class="btn btn-pdf">📄 XUẤT PDF (<span id="count">0</span>)</button>
    </div>

    <div id="status">Đang khởi tạo máy ảnh...</div>
    <canvas id="hidden-canvas" style="display:none;"></canvas>

    <div class="footer">Thiết kế bởi: <b>Võ Quang Nhã</b> - THPT Phú Bài</div>

    <script>
        const video = document.getElementById('webcam');
        const gallery = document.getElementById('gallery');
        const editor = document.getElementById('editor');
        const eCanvas = document.getElementById('editor-canvas');
        const status = document.getElementById('status');
        
        let pages = []; // Lưu trữ danh sách các trang
        let activeIdx = -1;
        let curRotate = 0;

        // 1. Mở Camera (Hỗ trợ chạy Localhost)
        async function initCamera() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: "environment", width: 1280, height: 720 },
                    audio: false 
                });
                video.srcObject = stream;
                status.innerText = "Sẵn sàng quét tài liệu!";
            } catch (err) {
                status.innerText = "Lỗi: Hãy chạy qua HTTPS hoặc Localhost!";
                console.error(err);
            }
        }

        // 2. Chụp ảnh trang mới
        document.getElementById('btn-snap').onclick = () => {
            const canvas = document.getElementById('hidden-canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0);

            const data = canvas.toDataURL('image/jpeg', 0.9);
            pages.push({ original: data, current: data, b: 0, c: 0, r: 0 });
            
            updateGallery();
            status.innerText = `Đã thêm trang số ${pages.length}`;
        };

        function updateGallery() {
            gallery.innerHTML = '';
            pages.forEach((p, i) => {
                const img = document.createElement('img');
                img.src = p.current;
                img.className = 'thumb' + (i === activeIdx ? ' active' : '');
                img.onclick = () => openEditor(i);
                gallery.appendChild(img);
            });
            document.getElementById('count').innerText = pages.length;
        }

        // 3. Trình chỉnh sửa
        function openEditor(idx) {
            activeIdx = idx;
            editor.style.display = 'block';
            const p = pages[idx];
            document.getElementById('bright').value = p.b;
            document.getElementById('contrast').value = p.c;
            curRotate = p.r;
            renderPreview();
            updateGallery();
            editor.scrollIntoView({ behavior: 'smooth' });
        }

        function renderPreview() {
            if (activeIdx === -1) return;
            const img = new Image();
            img.src = pages[activeIdx].original;
            img.onload = () => {
                const ctx = eCanvas.getContext('2d');
                // Tính toán kích thước theo góc xoay
                if (curRotate % 180 === 0) {
                    eCanvas.width = img.width; eCanvas.height = img.height;
                } else {
                    eCanvas.width = img.height; eCanvas.height = img.width;
                }

                ctx.save();
                ctx.translate(eCanvas.width/2, eCanvas.height/2);
                ctx.rotate(curRotate * Math.PI / 180);
                ctx.drawImage(img, -img.width/2, -img.height/2);
                ctx.restore();

                // Áp dụng lọc màu
                const b = parseInt(document.getElementById('bright').value);
                const c = parseInt(document.getElementById('contrast').value);
                const idata = ctx.getImageData(0, 0, eCanvas.width, eCanvas.height);
                const data = idata.data;
                const factor = (259 * (c + 255)) / (255 * (259 - c));

                for (let i = 0; i < data.length; i += 4) {
                    data[i] = factor * (data[i] + b - 128) + 128;
                    data[i+1] = factor * (data[i+1] + b - 128) + 128;
                    data[i+2] = factor * (data[i+2] + b - 128) + 128;
                }
                ctx.putImageData(idata, 0, 0);
            };
        }

        document.getElementById('bright').oninput = renderPreview;
        document.getElementById('contrast').oninput = renderPreview;

        function rotateImg() { curRotate = (curRotate + 90) % 360; renderPreview(); }

        function saveEdit() {
            pages[activeIdx].current = eCanvas.toDataURL('image/jpeg', 0.8);
            pages[activeIdx].b = document.getElementById('bright').value;
            pages[activeIdx].c = document.getElementById('contrast').value;
            pages[activeIdx].r = curRotate;
            editor.style.display = 'none';
            activeIdx = -1;
            updateGallery();
            status.innerText = "Đã cập nhật trang chỉnh sửa.";
        }

        // 4. Xuất file PDF
        document.getElementById('btn-pdf').onclick = () => {
            if (pages.length === 0) return alert("Cô hãy chụp ít nhất 1 trang!");
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');
            status.innerText = "Đang tạo PDF...";

            pages.forEach((p, i) => {
                if (i > 0) doc.addPage();
                doc.addImage(p.current, 'JPEG', 10, 10, 190, 277);
            });

            doc.save("Scan_STEM_PhuBai.pdf");
            status.innerText = "Đã xuất PDF thành công!";
        };

        initCamera();
    </script>
</body>
</html>
